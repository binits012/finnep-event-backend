{
  "name": "finnep-eventapp-backend",
  "version": "0.0.0",
  "private": true,
  "author": "Binit Shrestha",
  "license": "MIT",
  "company": "Finnep",
  "description": "Finnep Event App",
  "keywords": [
    "finnep",
    "eventapp",
    "event",
    "app",
    "event management"
  ],
  "homepage": "https://eventapp.finnep.fi",
  "scripts": {
    "start": "nodemon --exec node app.js",
    "esbuild": "node esbuild.config.js",
    "docs:generate": "node scripts/generateSwagger.js",
    "migrate": "node scripts/migrate-schemas.js",
    "migrate:user-regional-scopes": "node scripts/backfill-user-regional-scopes.mjs",
    "migrate:event-end-date": "node scripts/backfill-event-end-date.mjs",
    "migrate:event-short-code": "node scripts/backfill-event-short-code.mjs",
    "warm:shortlink-cache": "node scripts/warm-shortlink-cache.mjs",
    "preview:email": "node scripts/preview-email.js",
    "preview:email:list": "node scripts/preview-email.js --list",
    "test:email:templates": "node scripts/test-all-email-templates.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=unit",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPattern=integration",
    "test:ci": "NODE_OPTIONS=--experimental-vm-modules jest --ci --coverage --maxWorkers=2"
  },
  "type": "module",
  "overrides": {
    "html-minifier": "~7.2.0"
  },
  "dependencies": {
    "amqplib": "~0.10.9",
    "compression": "~1.8.1",
    "cookie-parser": "~1.4.7",
    "express": "~4.22.1",
    "handlebars": "~4.7.9",
    "mjml": "~5.0.1",
    "node-fetch": "~3.3.2",
    "stripe": "~16.12.0",
    "swagger-jsdoc": "~6.2.8",
    "swagger-ui-express": "~5.0.1",
    "uuid": "~11.1.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "~3.993.0",
    "@aws-sdk/cloudfront-signer": "~3.956.0",
    "@aws-sdk/lib-storage": "~3.956.0",
    "@hokify/agenda": "~6.3.0",
    "@jest/globals": "~29.7.0",
    "@types/jest": "~30.0.0",
    "@types/supertest": "~6.0.3",
    "bcrypt": "~6.0.0",
    "bullmq": "~5.66.2",
    "busboy": "~1.6.0",
    "copy-webpack-plugin": "~14.0.0",
    "cors": "~2.8.5",
    "dotenv": "~16.6.1",
    "esbuild": "~0.25.12",
    "exceljs": "~4.4.0",
    "express-validator": "~7.3.1",
    "ics": "~3.8.1",
    "jest": "~29.7.0",
    "jest-mock-extended": "~4.0.0",
    "jsonwebtoken": "~9.0.3",
    "moment": "~2.30.1",
    "moment-timezone": "~0.5.48",
    "mongodb-memory-server": "~10.4.2",
    "mongoose": "~7.8.8",
    "nodemailer": "~8.0.5",
    "nodemon": "~3.1.11",
    "qrcode": "~1.5.4",
    "redis": "~4.7.1",
    "supertest": "~7.1.4",
    "winston": "~3.19.0",
    "winston-daily-rotate-file": "~4.7.1"
  }
}
